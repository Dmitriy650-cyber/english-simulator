<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp">

    <!--  ListViewItem  -->
    <Style x:Key="ListViewItem" TargetType="ListViewItem">

        <!--  ListViewItem style  -->
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource titleColor3}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="4,0,0,0">
                        <ContentPresenter VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style.Triggers>

            <!--  ListViewItem on hover  -->
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Margin" Value="5,0,0,0" />
                <Setter Property="Foreground" Value="{StaticResource titleColor1}" />
                <Setter Property="Background" Value="{StaticResource panelOverColor}" />
                <Setter Property="BorderBrush" Value="{Binding Path=Tag, RelativeSource={RelativeSource Self}}" />
            </Trigger>

            <!--  ListViewItem on selected  -->
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Margin" Value="5,0,0,0" />
                <Setter Property="Foreground" Value="{StaticResource titleColor1}" />
                <Setter Property="Background" Value="{StaticResource panelActiveColor}" />
                <Setter Property="BorderBrush" Value="{Binding Path=Tag, RelativeSource={RelativeSource Self}}" />
            </Trigger>

        </Style.Triggers>

    </Style>

    <!--  ListViewItem text  -->
    <Style x:Key="ListViewItemText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=ListViewItem}}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="FontSize" Value="13.5" />
    </Style>

</ResourceDictionary>