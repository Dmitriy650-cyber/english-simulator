<basepage:BasePage
    x:Class="EnglishSimulator.Desktop.Views.Pages.SimulatorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:basepage="clr-namespace:EnglishSimulator.Desktop.Views.Pages.Base"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
    xmlns:local="clr-namespace:EnglishSimulator.Desktop.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:EnglishSimulator.Desktop.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:SimulatorViewModel,
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="530"
    d:DesignWidth="800"
    ViewModelType="{x:Type vm:SimulatorViewModel}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="35" />
            <RowDefinition Height="20" />
            <RowDefinition />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>

        <!--  Header / Caption  -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="150" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <!--  Caption  -->
            <StackPanel
                Grid.Column="0"
                VerticalAlignment="Center"
                Orientation="Horizontal">

                <Button
                    Margin="20,0,10,0"
                    Command="{Binding BackCommand}"
                    Style="{StaticResource CircleButton}"
                    Tag="{StaticResource color3}">
                    <fa:IconImage
                        Width="34"
                        Height="34"
                        Icon="ArrowCircleLeft"
                        Style="{StaticResource CircleButtonIcon}" />
                </Button>

                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="16"
                    FontWeight="Medium"
                    Foreground="{StaticResource titleColor2}"
                    Text="ENGLISH SIMULATOR" />

            </StackPanel>

            <StackPanel
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal">

                <TextBlock
                    FontSize="20"
                    FontWeight="Bold"
                    Foreground="{StaticResource color9}"
                    Text="{Binding CountLearnedSentences}" />

                <TextBlock
                    Margin="10,0"
                    FontSize="20"
                    FontWeight="Bold"
                    Foreground="{StaticResource color8}"
                    Text="/" />

                <TextBlock
                    FontSize="20"
                    FontWeight="Bold"
                    Foreground="{StaticResource color4}"
                    Text="{Binding CountNewSentences}" />

            </StackPanel>

            <!--  Header  -->
            <Grid
                Grid.Column="2"
                Margin="0,0,10,0"
                VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="5"
                    Command="{Binding GoToHelpPageCommand}"
                    Style="{StaticResource iconButton}"
                    Tag="{StaticResource color1}">
                    <fa:IconImage
                        Width="12"
                        Height="12"
                        Icon="Question"
                        Style="{StaticResource iconButtonIcon}" />
                </Button>

                <TextBlock
                    Grid.Column="4"
                    VerticalAlignment="Center"
                    FontSize="16"
                    FontWeight="Medium"
                    Foreground="{StaticResource titleColor3}"
                    Text="{Binding Caption}" />

                <Slider
                    Grid.Column="3"
                    Width="100"
                    Margin="10,0"
                    VerticalAlignment="Center"
                    IsDirectionReversed="False"
                    IsSnapToTickEnabled="True"
                    Maximum="5"
                    Minimum="0"
                    Orientation="Horizontal"
                    Style="{StaticResource CustomSlider}"
                    TickFrequency="1"
                    Value="{Binding Speed}" />

                <TextBlock
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    FontSize="16"
                    FontWeight="Medium"
                    Foreground="{StaticResource titleColor3}"
                    Text="{Binding Speed}" />

                <TextBlock
                    Grid.Column="1"
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    FontSize="16"
                    FontWeight="Medium"
                    Foreground="{StaticResource titleColor3}"
                    Text="SPEED" />

            </Grid>

        </Grid>

        <TextBlock
            Grid.Row="1"
            Margin="20,0"
            HorizontalAlignment="Center"
            Foreground="{StaticResource titleColor3}"
            Text="{Binding TextInfo}" />

        <Grid Grid.Row="2" Margin="10,0">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>

            <ToggleButton
                Grid.Row="0"
                Content="{Binding Text1}"
                IsChecked="{Binding ToggleButton1Selected}"
                IsEnabled="{Binding ToggleButton1IsEnabled}"
                Style="{StaticResource SentenceToggleButton}"
                Tag="{StaticResource color1}" />

            <ToggleButton
                Grid.Row="1"
                Content="{Binding Text2}"
                IsChecked="{Binding ToggleButton2Selected}"
                IsEnabled="{Binding ToggleButton2IsEnabled}"
                Style="{StaticResource SentenceToggleButton}"
                Tag="{StaticResource color2}" />

            <ToggleButton
                Grid.Row="2"
                Content="{Binding Text3}"
                IsChecked="{Binding ToggleButton3Selected}"
                IsEnabled="{Binding ToggleButton3IsEnabled}"
                Style="{StaticResource SentenceToggleButton}"
                Tag="{StaticResource color3}" />

            <ToggleButton
                Grid.Row="3"
                Content="{Binding Text4}"
                IsChecked="{Binding ToggleButton4Selected}"
                IsEnabled="{Binding ToggleButton4IsEnabled}"
                Style="{StaticResource SentenceToggleButton}"
                Tag="{StaticResource color4}" />

            <ToggleButton
                Grid.Row="4"
                Content="{Binding Text5}"
                IsChecked="{Binding ToggleButton5Selected}"
                IsEnabled="{Binding ToggleButton5IsEnabled}"
                Style="{StaticResource SentenceToggleButton}"
                Tag="{StaticResource color5}" />

            <ToggleButton
                Grid.Row="5"
                Content="{Binding Text6}"
                IsChecked="{Binding ToggleButton6Selected}"
                IsEnabled="{Binding ToggleButton6IsEnabled}"
                Style="{StaticResource SentenceToggleButton}"
                Tag="{StaticResource color6}" />

            <ToggleButton
                Grid.Row="6"
                Content="{Binding Text7}"
                IsChecked="{Binding ToggleButton7Selected}"
                IsEnabled="{Binding ToggleButton7IsEnabled}"
                Style="{StaticResource SentenceToggleButton}"
                Tag="{StaticResource color7}" />

            <ToggleButton
                Grid.Row="7"
                Content="{Binding Text8}"
                IsChecked="{Binding ToggleButton8Selected}"
                IsEnabled="{Binding ToggleButton8IsEnabled}"
                Style="{StaticResource SentenceToggleButton}"
                Tag="{StaticResource color8}" />

            <ToggleButton
                Grid.Row="8"
                Content="{Binding Text9}"
                IsChecked="{Binding ToggleButton9Selected}"
                IsEnabled="{Binding ToggleButton9IsEnabled}"
                Style="{StaticResource SentenceToggleButton}"
                Tag="{StaticResource color9}" />

            <ToggleButton
                Grid.Row="9"
                Content="{Binding Text10}"
                IsChecked="{Binding ToggleButton10Selected}"
                IsEnabled="{Binding ToggleButton10IsEnabled}"
                Style="{StaticResource SentenceToggleButton}"
                Tag="{StaticResource color10}" />

        </Grid>

        <Button
            Grid.Row="3"
            Margin="20,0"
            Command="{Binding StartCommand}"
            Content="{Binding ButtonStartText}"
            Style="{StaticResource Button}"
            Tag="{StaticResource color1}" />

    </Grid>

</basepage:BasePage>
