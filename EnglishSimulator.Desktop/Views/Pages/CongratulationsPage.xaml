<basepage:BasePage
    x:Class="EnglishSimulator.Desktop.Views.Pages.CongratulationsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:basepage="clr-namespace:EnglishSimulator.Desktop.Views.Pages.Base"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:EnglishSimulator.Desktop.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:EnglishSimulator.Desktop.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:CongratulationsViewModel,
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="495"
    d:DesignWidth="800"
    ViewModelType="{x:Type vm:CongratulationsViewModel}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>

            <TextBlock
                Grid.Row="0"
                HorizontalAlignment="Center"
                FontSize="28"
                FontWeight="Bold"
                Foreground="{StaticResource titleColor1}"
                Text="Congratulations!" />

            <TextBlock
                Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="16"
                FontWeight="Medium"
                Foreground="{StaticResource titleColor1}"
                Text="You have completed today's training. See you tomorrow!" />

            <Button
                Grid.Row="2"
                Margin="5,0"
                Command="{Binding CompletedCommand}"
                Content="Completed"
                Style="{StaticResource Button}"
                Tag="{StaticResource color9}" />

        </Grid>

    </Grid>

</basepage:BasePage>
