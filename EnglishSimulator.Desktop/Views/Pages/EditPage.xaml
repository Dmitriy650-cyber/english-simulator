<basepage:BasePage
    x:Class="EnglishSimulator.Desktop.Views.Pages.EditPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:basepage="clr-namespace:EnglishSimulator.Desktop.Views.Pages.Base"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
    xmlns:local="clr-namespace:EnglishSimulator.Desktop.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:EnglishSimulator.Desktop.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:EditViewModel,
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="530"
    d:DesignWidth="800"
    ViewModelType="{x:Type vm:EditViewModel}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="35" />
            <RowDefinition Height="60" />
            <RowDefinition Height="20" />
            <RowDefinition />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>

        <!--  Header / Caption  -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <!--  Caption  -->
            <StackPanel
                Grid.Column="0"
                VerticalAlignment="Center"
                Orientation="Horizontal">

                <Button
                    Margin="20,0,10,0"
                    Command="{Binding GoBackCommand}"
                    Style="{StaticResource CircleButton}"
                    Tag="{StaticResource color3}">
                    <fa:IconImage
                        Width="34"
                        Height="34"
                        Icon="ArrowCircleLeft"
                        Style="{StaticResource CircleButtonIcon}" />
                </Button>

                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="16"
                    FontWeight="Medium"
                    Foreground="{StaticResource titleColor2}"
                    Text="ENGLISH SIMULATOR" />

            </StackPanel>

            <!--  Header  -->
            <StackPanel
                Grid.Column="1"
                Margin="0,0,18,0"
                VerticalAlignment="Center"
                FlowDirection="RightToLeft"
                Orientation="Horizontal">

                <Button Style="{StaticResource iconButton}" Tag="{StaticResource color1}">
                    <fa:IconImage
                        Width="12"
                        Height="12"
                        Icon="Question"
                        Style="{StaticResource iconButtonIcon}">
                        <fa:IconImage.RenderTransform>
                            <ScaleTransform ScaleX="-1" />
                        </fa:IconImage.RenderTransform>
                    </fa:IconImage>
                </Button>

                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="16"
                    FontWeight="Medium"
                    Foreground="{StaticResource titleColor3}"
                    Text="{Binding Caption}" />

            </StackPanel>

        </Grid>

        <Grid Grid.Row="1" Margin="20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <Button
                Grid.Column="0"
                Command="{Binding AddSentenceCommand}"
                Content="Add Phrase"
                Style="{StaticResource Button}"
                Tag="{StaticResource color9}" />

            <Button
                Grid.Column="1"
                Command="{Binding EditSentenceCommand}"
                Content="Edit Phrase"
                Style="{StaticResource Button}"
                Tag="{StaticResource color6}" />

            <Button
                Grid.Column="2"
                Command="{Binding DeleteSentenceCommand}"
                Content="Delete Phrase"
                Style="{StaticResource Button}"
                Tag="{StaticResource color4}" />

        </Grid>

        <Grid Grid.Row="2" Margin="20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="50" />
                <ColumnDefinition Width="50" />
                <ColumnDefinition Width="50" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Foreground="{StaticResource titleColor3}"
                Text="Phrase" />

            <TextBlock
                Grid.Column="1"
                Foreground="{StaticResource titleColor3}"
                Text="New" />

            <TextBlock
                Grid.Column="2"
                Foreground="{StaticResource titleColor3}"
                Text="Learn" />

            <TextBlock
                Grid.Column="3"
                Foreground="{StaticResource titleColor3}"
                Text="Due" />

        </Grid>

        <ListView
            Grid.Row="3"
            Margin="10,0"
            HorizontalContentAlignment="Stretch"
            Background="Transparent"
            BorderThickness="0"
            ItemsSource="{Binding Sentences}"
            SelectedItem="{Binding SelectedSentence}">
            <ListView.ItemContainerStyle>
                <Style BasedOn="{StaticResource ListViewItem}" TargetType="ListViewItem">
                    <Setter Property="Tag" Value="{StaticResource color2}" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="50" />
                            <ColumnDefinition Width="50" />
                            <ColumnDefinition Width="50" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            Style="{StaticResource ListViewItemText}"
                            Text="Deck 1" />

                        <TextBlock
                            Grid.Column="1"
                            FontSize="13.5"
                            FontWeight="Bold"
                            Foreground="{StaticResource color8}"
                            Text="10" />

                        <TextBlock
                            Grid.Column="2"
                            FontSize="13.5"
                            FontWeight="Bold"
                            Foreground="{StaticResource color10}"
                            Text="10" />

                        <TextBlock
                            Grid.Column="3"
                            FontSize="13.5"
                            FontWeight="Bold"
                            Foreground="{StaticResource color9}"
                            Text="1" />

                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Button
            Grid.Row="4"
            Margin="20,0"
            Content="Settings"
            Style="{StaticResource Button}"
            Tag="{StaticResource color1}" />

    </Grid>

</basepage:BasePage>
