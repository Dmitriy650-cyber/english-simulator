<UserControl
    x:Class="EnglishSimulator.Desktop.Views.Pages.DeckPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:EnglishSimulator.Desktop.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="495"
    d:DesignWidth="800"
    DataContext="{Binding DeckViewModel, Source={StaticResource Locator}}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="20" />
            <RowDefinition />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <Button
                Grid.Column="0"
                Content="Add Deck"
                Style="{StaticResource Button}"
                Tag="{StaticResource color9}" />

            <Button
                Grid.Column="1"
                Content="Edit Deck"
                Style="{StaticResource Button}"
                Tag="{StaticResource color6}" />

            <Button
                Grid.Column="2"
                Content="Delete Deck"
                Style="{StaticResource Button}"
                Tag="{StaticResource color4}" />

        </Grid>

        <Grid Grid.Row="1" Margin="10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="50" />
                <ColumnDefinition Width="50" />
                <ColumnDefinition Width="50" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Foreground="{StaticResource titleColor3}"
                Text="Deck" />

            <TextBlock
                Grid.Column="1"
                Foreground="{StaticResource titleColor3}"
                Text="New" />

            <TextBlock
                Grid.Column="2"
                Foreground="{StaticResource titleColor3}"
                Text="Learn" />

            <TextBlock
                Grid.Column="3"
                Foreground="{StaticResource titleColor3}"
                Text="Due" />

        </Grid>

        <ListView
            Grid.Row="2"
            HorizontalContentAlignment="Stretch"
            Background="Transparent"
            BorderThickness="0"
            ItemsSource="{Binding TestItems}">
            <ListView.ItemContainerStyle>
                <Style BasedOn="{StaticResource ListViewItem}" TargetType="ListViewItem">
                    <Setter Property="Tag" Value="{StaticResource color2}" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="50" />
                            <ColumnDefinition Width="50" />
                            <ColumnDefinition Width="50" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            Style="{StaticResource ListViewItemText}"
                            Text="Deck 1" />

                        <TextBlock
                            Grid.Column="1"
                            FontSize="13.5"
                            FontWeight="Bold"
                            Foreground="{StaticResource color8}"
                            Text="10" />

                        <TextBlock
                            Grid.Column="2"
                            FontSize="13.5"
                            FontWeight="Bold"
                            Foreground="{StaticResource color10}"
                            Text="10" />

                        <TextBlock
                            Grid.Column="3"
                            FontSize="13.5"
                            FontWeight="Bold"
                            Foreground="{StaticResource color9}"
                            Text="1" />

                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Button
            Grid.Row="3"
            Content="Start Lesson"
            Style="{StaticResource Button}"
            Tag="{StaticResource color1}" />

    </Grid>

</UserControl>
