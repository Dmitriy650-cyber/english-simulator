<Window
    x:Class="EnglishSimulator.Desktop.Views.Windows.DialogWindows.RepetitionIntervalsDialogWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
    xmlns:local="clr-namespace:EnglishSimulator.Desktop.Views.Windows.DialogWindows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:EnglishSimulator.Desktop.ViewModels.DialogViewModels"
    Title="RepetitionIntervalsDialogWindow"
    Width="480"
    Height="300"
    d:DataContext="{d:DesignInstance Type=vm:RepetitionIntervalsDialogViewModel,
                                     IsDesignTimeCreatable=False}"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">

    <Grid>

        <Border
            BorderThickness="1"
            CornerRadius="10"
            Opacity="0.95">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0" Color="{StaticResource winBorderColor1}" />
                    <GradientStop Offset="0.75" Color="{StaticResource winBorderColor2}" />
                    <GradientStop Offset="1" Color="{StaticResource winBorderColor3}" />
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.Background>
                <LinearGradientBrush StartPoint="1,1" EndPoint="0,0">
                    <GradientStop Offset="0" Color="{StaticResource primaryBackColor1}" />
                    <GradientStop Offset="1" Color="{StaticResource primaryBackColor2}" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid Margin="5,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="25" />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <StackPanel
                    x:Name="pnlControlBar"
                    Grid.Row="0"
                    Grid.ColumnSpan="2"
                    Margin="0,0,0,0"
                    Background="Transparent"
                    FlowDirection="RightToLeft"
                    MouseDown="pnlControlBar_MouseDown"
                    Orientation="Horizontal">

                    <Button
                        x:Name="btnClose"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource controlButton}"
                        Tag="{StaticResource color4}">
                        <fa:IconImage Icon="Xmark" Style="{StaticResource contolButtonIcon}" />
                    </Button>

                </StackPanel>

                <TextBlock
                    Grid.Row="1"
                    Grid.Column="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="14"
                    FontWeight="Medium"
                    Foreground="{StaticResource titleColor1}"
                    Text="STAGE 0" />

                <TextBox
                    Grid.Row="1"
                    Grid.Column="1"
                    Height="28"
                    Margin="0,0,0,0"
                    Padding="0,0,0,0"
                    VerticalAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="{StaticResource panelColor}"
                    BorderBrush="DarkGray"
                    BorderThickness="0,0,0,0"
                    CaretBrush="LightGray"
                    FontSize="13"
                    FontWeight="Medium"
                    Foreground="White"
                    Text="{Binding Stage0, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock
                    Grid.Row="2"
                    Grid.Column="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="14"
                    FontWeight="Medium"
                    Foreground="{StaticResource titleColor1}"
                    Text="STAGE 1" />

                <TextBox
                    Grid.Row="2"
                    Grid.Column="1"
                    Height="28"
                    Margin="0,0,0,0"
                    Padding="0,0,0,0"
                    VerticalAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="{StaticResource panelColor}"
                    BorderBrush="DarkGray"
                    BorderThickness="0,0,0,0"
                    CaretBrush="LightGray"
                    FontSize="13"
                    FontWeight="Medium"
                    Foreground="White"
                    Text="{Binding Stage1, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock
                    Grid.Row="3"
                    Grid.Column="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="14"
                    FontWeight="Medium"
                    Foreground="{StaticResource titleColor1}"
                    Text="STAGE 2" />

                <TextBox
                    Grid.Row="3"
                    Grid.Column="1"
                    Height="28"
                    Margin="0,0,0,0"
                    Padding="0,0,0,0"
                    VerticalAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="{StaticResource panelColor}"
                    BorderBrush="DarkGray"
                    BorderThickness="0,0,0,0"
                    CaretBrush="LightGray"
                    FontSize="13"
                    FontWeight="Medium"
                    Foreground="White"
                    Text="{Binding Stage2, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock
                    Grid.Row="4"
                    Grid.Column="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="14"
                    FontWeight="Medium"
                    Foreground="{StaticResource titleColor1}"
                    Text="STAGE 3" />

                <TextBox
                    Grid.Row="4"
                    Grid.Column="1"
                    Height="28"
                    Margin="0,0,0,0"
                    Padding="0,0,0,0"
                    VerticalAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="{StaticResource panelColor}"
                    BorderBrush="DarkGray"
                    BorderThickness="0,0,0,0"
                    CaretBrush="LightGray"
                    FontSize="13"
                    FontWeight="Medium"
                    Foreground="White"
                    Text="{Binding Stage3, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock
                    Grid.Row="5"
                    Grid.Column="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="14"
                    FontWeight="Medium"
                    Foreground="{StaticResource titleColor1}"
                    Text="STAGE 4" />

                <TextBox
                    Grid.Row="5"
                    Grid.Column="1"
                    Height="28"
                    Margin="0,0,0,0"
                    Padding="0,0,0,0"
                    VerticalAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="{StaticResource panelColor}"
                    BorderBrush="DarkGray"
                    BorderThickness="0,0,0,0"
                    CaretBrush="LightGray"
                    FontSize="13"
                    FontWeight="Medium"
                    Foreground="White"
                    Text="{Binding Stage4, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock
                    Grid.Row="6"
                    Grid.Column="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="14"
                    FontWeight="Medium"
                    Foreground="{StaticResource titleColor1}"
                    Text="STAGE 5" />

                <TextBox
                    Grid.Row="6"
                    Grid.Column="1"
                    Height="28"
                    Margin="0,0,0,0"
                    Padding="0,0,0,0"
                    VerticalAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="{StaticResource panelColor}"
                    BorderBrush="DarkGray"
                    BorderThickness="0,0,0,0"
                    CaretBrush="LightGray"
                    FontSize="13"
                    FontWeight="Medium"
                    Foreground="White"
                    Text="{Binding Stage5, UpdateSourceTrigger=PropertyChanged}" />

                <Button
                    Grid.Row="7"
                    Grid.Column="0"
                    Command="{Binding CancelCommand}"
                    Content="Cancel"
                    Style="{StaticResource Button}"
                    Tag="{StaticResource color4}" />

                <Button
                    Grid.Row="7"
                    Grid.Column="1"
                    Command="{Binding NewOkCommand}"
                    Content="Ok"
                    Style="{StaticResource Button}"
                    Tag="{StaticResource color9}" />

            </Grid>

        </Border>

    </Grid>

</Window>
