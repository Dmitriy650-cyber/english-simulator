<Window
    x:Class="EnglishSimulator.Desktop.Views.Windows.DialogWindows.SentenceDialogWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
    xmlns:local="clr-namespace:EnglishSimulator.Desktop.Views.Windows.DialogWindows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:EnglishSimulator.Desktop.ViewModels.DialogViewModels"
    Title="SentenceDialogWindow"
    Width="600"
    Height="400"
    d:DataContext="{d:DesignInstance Type=vm:SentenceDialogViewModel,
                                     IsDesignTimeCreatable=False}"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">

    <Grid>

        <Border
            BorderThickness="1"
            CornerRadius="10"
            Opacity="0.95">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0" Color="{StaticResource winBorderColor1}" />
                    <GradientStop Offset="0.75" Color="{StaticResource winBorderColor2}" />
                    <GradientStop Offset="1" Color="{StaticResource winBorderColor3}" />
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.Background>
                <LinearGradientBrush StartPoint="1,1" EndPoint="0,0">
                    <GradientStop Offset="0" Color="{StaticResource primaryBackColor1}" />
                    <GradientStop Offset="1" Color="{StaticResource primaryBackColor2}" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="25" />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <StackPanel
                    x:Name="pnlControlBar"
                    Grid.Row="0"
                    Margin="0,0,5,0"
                    Background="Transparent"
                    FlowDirection="RightToLeft"
                    MouseDown="pnlControlBar_MouseDown"
                    Orientation="Horizontal">

                    <Button
                        x:Name="btnClose"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource controlButton}"
                        Tag="{StaticResource color4}">
                        <fa:IconImage Icon="Xmark" Style="{StaticResource contolButtonIcon}" />
                    </Button>

                </StackPanel>

                <StackPanel
                    Grid.Row="1"
                    Margin="10,0"
                    VerticalAlignment="Center"
                    Orientation="Vertical">

                    <TextBlock
                        FontSize="13.5"
                        Foreground="{StaticResource titleColor1}"
                        Text="ENTER RUSSIAN TEXT" />

                    <TextBox
                        Height="28"
                        Margin="0,5,0,0"
                        Padding="0,0,0,0"
                        VerticalContentAlignment="Center"
                        Background="{StaticResource panelColor}"
                        BorderBrush="DarkGray"
                        BorderThickness="0,0,0,0"
                        CaretBrush="LightGray"
                        FontSize="13"
                        FontWeight="Medium"
                        Foreground="White"
                        Text="{Binding RussianText, UpdateSourceTrigger=PropertyChanged}" />

                </StackPanel>

                <StackPanel
                    Grid.Row="2"
                    Margin="10,0"
                    VerticalAlignment="Center"
                    Orientation="Vertical">

                    <TextBlock
                        FontSize="13.5"
                        Foreground="{StaticResource titleColor1}"
                        Text="CHOOSE/CREATE RUSSIAN AUDIO" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="8*" />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            Height="28"
                            Background="{StaticResource panelColor}"
                            FontSize="13"
                            FontWeight="Medium"
                            Foreground="White"
                            Text="{Binding RussianAudio}" />

                        <Button
                            Grid.Column="1"
                            Style="{StaticResource iconButton}"
                            Tag="{StaticResource color1}">
                            <fa:IconImage
                                Width="20"
                                Height="20"
                                Icon="FileAudio"
                                Style="{StaticResource iconButtonIcon}" />
                        </Button>

                        <Button
                            Grid.Column="2"
                            Style="{StaticResource iconButton}"
                            Tag="{StaticResource color3}">
                            <fa:IconImage
                                Width="20"
                                Height="20"
                                Icon="RecordVinyl"
                                Style="{StaticResource iconButtonIcon}" />
                        </Button>

                    </Grid>

                </StackPanel>

                <StackPanel
                    Grid.Row="3"
                    Margin="10,0"
                    VerticalAlignment="Center"
                    Orientation="Vertical">

                    <TextBlock
                        FontSize="13.5"
                        Foreground="{StaticResource titleColor1}"
                        Text="ENTER ENGLISH TEXT" />

                    <TextBox
                        Height="28"
                        Margin="0,5,0,0"
                        Padding="0,0,0,0"
                        VerticalContentAlignment="Center"
                        Background="{StaticResource panelColor}"
                        BorderBrush="DarkGray"
                        BorderThickness="0,0,0,0"
                        CaretBrush="LightGray"
                        FontSize="13"
                        FontWeight="Medium"
                        Foreground="White"
                        Text="{Binding EnglishText, UpdateSourceTrigger=PropertyChanged}" />

                </StackPanel>

                <StackPanel
                    Grid.Row="4"
                    Margin="10,0"
                    VerticalAlignment="Center"
                    Orientation="Vertical">

                    <TextBlock
                        FontSize="13.5"
                        Foreground="{StaticResource titleColor1}"
                        Text="CHOOSE/CREATE ENGLISH AUDIO" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="8*" />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            Height="28"
                            Background="{StaticResource panelColor}"
                            FontSize="13"
                            FontWeight="Medium"
                            Foreground="White"
                            Text="{Binding EnglishAudio}" />

                        <Button
                            Grid.Column="1"
                            Style="{StaticResource iconButton}"
                            Tag="{StaticResource color1}">
                            <fa:IconImage
                                Width="20"
                                Height="20"
                                Icon="FileAudio"
                                Style="{StaticResource iconButtonIcon}" />
                        </Button>

                        <Button
                            Grid.Column="2"
                            Style="{StaticResource iconButton}"
                            Tag="{StaticResource color3}">
                            <fa:IconImage
                                Width="20"
                                Height="20"
                                Icon="RecordVinyl"
                                Style="{StaticResource iconButtonIcon}" />
                        </Button>

                    </Grid>

                </StackPanel>

                <Grid
                    Grid.Row="5"
                    Margin="10,0"
                    VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        Command="{Binding CancelCommand}"
                        Content="Cancel"
                        Style="{StaticResource Button}"
                        Tag="{StaticResource color4}" />

                    <Button
                        Grid.Column="1"
                        Command="{Binding OkCommand}"
                        Content="Ok"
                        Style="{StaticResource Button}"
                        Tag="{StaticResource color9}" />

                </Grid>

            </Grid>

        </Border>

    </Grid>

</Window>
