<Window
    x:Class="EnglishSimulator.Desktop.Views.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
    xmlns:local="clr-namespace:EnglishSimulator.Desktop.Views.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:EnglishSimulator.Desktop.Views.Pages"
    xmlns:vm="clr-namespace:EnglishSimulator.Desktop.ViewModels"
    Width="850"
    Height="600"
    AllowsTransparency="True"
    Background="Transparent"
    DataContext="{Binding MainViewModel, Source={StaticResource Locator}}"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">

    <Window.Resources>

        <DataTemplate DataType="{x:Type vm:CongratulationsViewModel}">
            <pages:CongratulationsPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DeckViewModel}">
            <pages:DeckPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EditViewModel}">
            <pages:EditPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HelpViewModel}">
            <pages:HelpPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SimulatorViewModel}">
            <pages:SimulatorPage />
        </DataTemplate>

    </Window.Resources>

    <Grid>

        <Border CornerRadius="12">
            <Border.Background>
                <ImageBrush ImageSource="/Resources/Images/background.jpg" Stretch="UniformToFill" />
            </Border.Background>
            <Border
                BorderThickness="1"
                CornerRadius="10"
                Opacity="0.95">
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0" Color="{StaticResource winBorderColor1}" />
                        <GradientStop Offset="0.75" Color="{StaticResource winBorderColor2}" />
                        <GradientStop Offset="1" Color="{StaticResource winBorderColor3}" />
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.Background>
                    <LinearGradientBrush StartPoint="1,1" EndPoint="0,0">
                        <GradientStop Offset="0" Color="{StaticResource primaryBackColor1}" />
                        <GradientStop Offset="1" Color="{StaticResource primaryBackColor2}" />
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="25" />
                        <RowDefinition />
                    </Grid.RowDefinitions>

                    <!--  Control bar  -->
                    <StackPanel
                        x:Name="pnlControlBar"
                        Grid.Row="0"
                        Margin="0,0,5,0"
                        Background="Transparent"
                        FlowDirection="RightToLeft"
                        MouseEnter="pnlControlBar_MouseEnter"
                        MouseLeftButtonDown="pnlControlBar_MouseLeftButtonDown"
                        Orientation="Horizontal">

                        <Button
                            x:Name="btnClose"
                            Click="btnClose_Click"
                            Style="{StaticResource controlButton}"
                            Tag="{StaticResource color4}">
                            <fa:IconImage Icon="Xmark" Style="{StaticResource contolButtonIcon}" />
                        </Button>

                        <Button
                            x:Name="btnMaximize"
                            Click="btnMaximize_Click"
                            Style="{StaticResource controlButton}"
                            Tag="{StaticResource color6}">
                            <fa:IconImage Icon="Square" Style="{StaticResource contolButtonIcon}" />
                        </Button>

                        <Button
                            x:Name="btnMinimize"
                            Click="btnMinimize_Click"
                            Style="{StaticResource controlButton}"
                            Tag="{StaticResource color8}">
                            <fa:IconImage
                                Width="12"
                                Icon="WindowMinimize"
                                Style="{StaticResource contolButtonIcon}" />
                        </Button>

                    </StackPanel>

                    <!--  Content  -->
                    <ContentControl
                        Grid.Row="1"
                        Margin="0"
                        Content="{Binding CurrentChildPage}" />

                </Grid>

            </Border>
        </Border>

    </Grid>

</Window>
